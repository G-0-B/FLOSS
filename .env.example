# FLOSSIØULLK local inference credentials — EXAMPLE FILE
# Copy to `.env` and fill in your own keys. `.env` is gitignored, this example is committed.

# Cerebras Wafer-Scale Cloud — https://cloud.cerebras.ai
# Free tier: 14,400 requests/day, 60,000 TPM, 1M daily token cap
CEREBRAS_API_KEY=csk-...

# Groq LPU — https://console.groq.com
# Free tier: 14,400 requests/day, 18,000 TPM
GROQ_API_KEY=gsk-...

# Optional consensus roster controls
# Built-in profiles: balanced (default), fast, flowith, subscriptions, amplified
# FLOSS_VOTER_PROFILE=balanced
#
# Full roster override (replaces the built-in profile):
# FLOSS_VOTER_ROSTER=cerebras-llama3.1-8b=cerebras/llama3.1-8b;groq-gpt-oss-20b=groq/openai/gpt-oss-20b
#
# Extra voters appended to the selected built-in profile:
# FLOSS_EXTRA_VOTERS=gemini-flash=gemini/<your-supported-model>;flowith-deepseek=flowith/deepseek-chat|gpt-4.1-mini

# Flowith multi-model endpoint (optional; if unset, ~/.flowith/credentials.json is used)
# FLOWITH_API_KEY=flo_...
# Optional override for the Flowith credential file path
# FLOWITH_CREDENTIALS_PATH=C:/Users/<you>/.flowith/credentials.json

# Google AI Studio / Gemini (optional; only needed if you add gemini/* voters)
# GOOGLE_API_KEY=...
# GEMINI_API_KEY=...

# Optional fallbacks for later
# OPENROUTER_API_KEY=sk-or-...
# XAI_API_KEY=xai-...
