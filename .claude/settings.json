{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hook_post_write.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7-plugin@context7-marketplace": true
  }
}