{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flossioullk.org/specs/thought-credential/1.0.0",
  "title": "ThoughtCredential",
  "description": "A verifiable thoughtform with semantic content, emotional connotation, provenance signature, and community resonance.",
  "type": "object",
  "required": ["content", "connotation", "provenance", "resonance", "impact"],
  "properties": {
    "content": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 32,
      "maxItems": 4096,
      "description": "SemanticVector — embedding of the thoughtform, dimension in [32, 4096]"
    },
    "connotation": {
      "type": "integer",
      "minimum": -1,
      "maximum": 1,
      "description": "TernaryScore — emotional valence: -1 (negative), 0 (neutral), 1 (positive)"
    },
    "provenance": {
      "type": "string",
      "description": "AgentPubKey of the originating agent"
    },
    "resonance": {
      "type": "array",
      "items": { "type": "string" },
      "description": "AgentEndorsement — list of AgentPubKeys who resonate with this thoughtform"
    },
    "impact": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "WisdomMetric — measured impact score in [0.0, 1.0]"
    }
  },
  "additionalProperties": false
}
