{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flossi0ullk.org/schemas/consensus-gate/v0.1.0",
  "title": "Consensus Gate Schemas",
  "description": "Claim, Vote, and Decision schemas for the FLOSSI0ULLK Consensus Gate (ADR-6 Seam 1)",
  "definitions": {
    "Claim": {
      "type": "object",
      "required": [
        "id",
        "proposer",
        "proposal_type",
        "summary",
        "body",
        "truth_status",
        "blast_radius",
        "submitted_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-7[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
          "description": "UUID v7 (time-sortable)"
        },
        "proposer": {
          "type": "string",
          "minLength": 1,
          "description": "Agent public key or identifier"
        },
        "proposal_type": {
          "type": "string",
          "enum": [
            "CodeChange",
            "ConfigChange",
            "SpecChange",
            "AdrChange",
            "Other"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "truth_status": {
          "type": "string",
          "enum": ["Unverified"],
          "description": "Always Unverified on submission; upgraded by decision outcome"
        },
        "blast_radius": {
          "type": "string",
          "enum": ["Local", "Module", "System", "Substrate"]
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "ref"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["spec", "test", "adr", "url", "commit"]
              },
              "ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "submitted_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "Vote": {
      "type": "object",
      "required": ["voter", "weight", "rationale", "voted_at"],
      "properties": {
        "voter": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "number",
          "minimum": -0.999,
          "maximum": 0.999,
          "description": "Analog support signal in [-0.999, 0.999]; positive supports, negative opposes, near-zero abstains"
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "voted_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "Decision": {
      "type": "object",
      "required": ["claim_id", "outcome", "votes", "decided_at"],
      "properties": {
        "claim_id": {
          "type": "string",
          "format": "uuid",
          "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-7[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
          "description": "UUID v7 of the Claim this decision concerns"
        },
        "outcome": {
          "type": "string",
          "enum": ["APPROVED", "CONFLICT", "DEFERRED", "REJECTED", "OVERRIDDEN"]
        },
        "votes": {
          "type": "array",
          "minItems": 0,
          "items": { "$ref": "#/definitions/Vote" }
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "adr_ref": {
          "type": "string",
          "description": "Path to ADR stub recording this decision"
        },
        "override_by": {
          "type": "string",
          "description": "Human identity if outcome is OVERRIDDEN"
        },
        "tally_mean": {
          "type": "number",
          "description": "Arithmetic mean of the vote weights considered for this decision"
        },
        "tally_variance": {
          "type": "number",
          "minimum": 0,
          "description": "Population variance of the vote weights considered for this decision"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "outcome": { "const": "OVERRIDDEN" } }
          },
          "then": {
            "required": ["override_by"]
          },
          "else": {
            "not": {
              "required": ["override_by"]
            }
          }
        }
      ]
    }
  }
}
